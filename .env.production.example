# Copy this file to .env.production on your server and fill in the values.
# $ cp .env.production.example .env.production

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://cukaivault.my

# ── Gemini (used by OCR service) ──────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Admin access ─────────────────────────────────────────────────────────────
ADMIN_EMAILS=your@email.com

# ── Note: These are set automatically by docker-compose, do not change ────────
# DATABASE_URL=file:/app/prisma/prod.db
# OCR_SERVICE_URL=http://cukaivault-ocr:8000
